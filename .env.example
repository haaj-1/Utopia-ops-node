# ─────────────────────────────────────────────────────────────────────────────
# Utopia Ops OS — environment variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4173
NODE_ENV=development


# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: "google" (free) | "openai" | "anthropic" | "deepseek"
# Google AI Studio is free with a generous daily quota — recommended.
LLM_PROVIDER=google


# ── Google AI Studio / Gemini (FREE) ─────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
# No credit card needed. Resets daily.
GOOGLE_AI_API_KEY=your-google-ai-studio-key-here
# gemini-1.5-flash = fastest + most generous free quota (recommended)
# gemini-1.5-pro   = smarter but lower free quota
GOOGLE_AI_MODEL=gemini-1.5-flash


# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional — defaults to claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022


# ── OpenAI ───────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
# Optional — defaults to gpt-4o
OPENAI_MODEL=gpt-4o


# ── DeepSeek ─────────────────────────────────────────────────────────────────
# Only needed if LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=ds-your-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# Recommended: deepseek-v4-pro or deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-pro


# ── Google AI Studio / Gemini ───────────────────────────────────────────────────
# Only needed if LLM_PROVIDER=google
GOOGLE_AI_API_KEY=AIza...
GOOGLE_AI_MODEL=gemini-prototype
# Optional override if Google changes the endpoint format
GOOGLE_API_URL=https://generativelanguage.googleapis.com/v1beta2/models


# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot Token (required for per-department routing)
#   1. Go to https://api.slack.com/apps and create an app.
#   2. Add the "chat:write" bot scope under OAuth & Permissions.
#   3. Install the app to your workspace.
#   4. Copy the "Bot User OAuth Token" (starts with xoxb-).
SLACK_BOT_TOKEN=xoxb-your-token-here

# Optional but recommended for Slack slash-command verification.
# Find it in your Slack app under Basic Information → Signing Secret.
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

# Fallback channel — used when a department channel is not set
SLACK_DEFAULT_CHANNEL=#ops-onboarding

# Per-department channels — the agent routes each message to the right team.
# If not set, falls back to SLACK_DEFAULT_CHANNEL.
SLACK_CHANNEL_OPS=#ops-onboarding
SLACK_CHANNEL_FINANCE=#finance-ops
SLACK_CHANNEL_TECH=#studio-tech

# Option B — Incoming Webhook (simpler, single channel only, no department routing)
#   1. In your Slack app, go to "Incoming Webhooks" and activate it.
#   2. Click "Add New Webhook to Workspace" and pick a channel.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL


# ── Linear ────────────────────────────────────────────────────────────────────
# Get your API key at: https://linear.app/settings/api
# Find your team ID in the Linear URL or via the API.
LINEAR_API_KEY=lin_api_your_key_here
LINEAR_TEAM_ID=your-linear-team-id


# ── Google Sheets ─────────────────────────────────────────────────────────────
# Publish your onboarding sheet as CSV:
#   File → Share → Publish to web → CSV → Copy link
#
# Required columns:
#   fellow_name, start_date, location, task, status, owner, due_date, criticality
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv


# ── Generic downstream webhook ────────────────────────────────────────────────
# Optional. Receives the full structured agent payload as JSON POST.
JSON_WEBHOOK_URL=https://your-internal-api.example.com/utopia/events


# ── Daily scheduler ─────────────────────────────────────────────────────────
# When enabled, the server runs the agent once per day at 09:00 Doha time.
# Toggle this from the dashboard, or set it manually here.
SCHEDULER_ENABLED=false
SCHEDULER_TIME=09:00
SCHEDULER_TIMEZONE=Asia/Qatar
# ── Optional encrypted env storage ────────────────────────────────────────────────────
# If you want secrets at rest encrypted, set a runtime master key outside of .env.
# Example: export SECRETS_MASTER_KEY="super-secret-key"
# The app will then save secrets to .env.enc instead of .env.
SECRETS_MASTER_KEY=
